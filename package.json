{
  "name": "retail-price-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/concurrently/dist/bin/concurrently.js \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "dev:backend": "node ./node_modules/tsx/dist/cli.mjs watch src/backend/server.ts",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "parse": "node ./node_modules/tsx/dist/cli.mjs src/backend/cli/parse.ts",
    "start": "node ./node_modules/tsx/dist/cli.mjs src/backend/server.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "playwright": "^1.57.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
